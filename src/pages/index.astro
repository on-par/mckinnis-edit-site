---
import { Image } from 'astro:assets';
import '../styles/global.css';

import logoLight from '../assets/brand/logo-light.png';

import hero from '../assets/photos/IMG_9619.jpg';
import svcBrand from '../assets/photos/IMG_9798.jpg';
import svcPortrait from '../assets/photos/IMG_9703.jpg';
import svcHeadshot from '../assets/photos/IMG_9664.jpg';
import svcEvent from '../assets/photos/IMG_9652.jpg';

import g1 from '../assets/photos/IMG_9442.jpg';
import g2 from '../assets/photos/IMG_9463.jpg';
import g3 from '../assets/photos/IMG_9482.jpg';
import g4 from '../assets/photos/IMG_9526.jpg';
import g5 from '../assets/photos/IMG_9534.jpg';
import g6 from '../assets/photos/IMG_9721.jpg';
import g7 from '../assets/photos/IMG_9437.jpg';
import g8 from '../assets/photos/IMG_9580.jpg';
import g9 from '../assets/photos/IMG_9688.jpg';

import workshopImg from '../assets/photos/IMG_9674.jpg';
import aboutBook from '../assets/photos/IMG_9734.jpg';
import aboutSecond from '../assets/photos/IMG_9516.jpg';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const email = 'mckinnis.edit@gmail.com';

const nav = [
  { href: '#work', label: 'Work' },
  { href: '#services', label: 'Services' },
  { href: '#memberships', label: 'Memberships' },
  { href: '#workshops', label: 'Workshops' },
  { href: '#about', label: 'About' },
  { href: '#contact', label: 'Contact' },
];

const services = [
  {
    n: '01',
    title: 'Brand Photography',
    img: svcBrand,
    alt: 'A graduate at a design studio work table, laying out fabric samples and holding a green swatch up to the light.',
    body: 'A library of images built around how your business actually works, so your website, your deck and your feed all sound like the same person.',
  },
  {
    n: '02',
    title: 'Portrait Photography',
    img: svcPortrait,
    alt: 'Close portrait of a graduate in an orange dress, resting her chin on her hands and smiling against a soft pink wall.',
    body: 'Personal, milestone and lifestyle portraits. We plan the session around the version of you that you already recognize, and then we go find it.',
  },
  {
    n: '03',
    title: 'Headshot Photography',
    img: svcHeadshot,
    alt: 'Seated three quarter portrait of a graduate wearing a UTSA stole, photographed in front of a bookshelf.',
    body: 'Professional headshots for individuals and full teams, shot with consistent light and framing so a directory page looks intentional rather than assembled.',
  },
  {
    n: '04',
    title: 'Event Photography',
    img: svcEvent,
    alt: 'Graduate in a navy gown holding her cap up in celebration, photographed on location in a design showroom.',
    body: 'Corporate, private and community events. Quiet coverage that stays out of the room and still comes back with the moments people will ask for.',
  },
];

const gallery = [
  { img: g1, alt: 'Graduate in an orange university shirt lifting her cap onto her head, photographed close and looking up.' },
  { img: g2, alt: 'Graduate laughing while reaching for a hanging fabric sample in a design showroom.' },
  { img: g3, alt: 'Graduate standing between two tall racks of wallpaper samples with both arms raised.' },
  { img: g4, alt: 'Graduate seated on a showroom sofa reading a design magazine, her cap resting beside her.' },
  { img: g5, alt: 'Graduate wearing her cap and peeking over the top of an Interior Design magazine.' },
  { img: g6, alt: 'Graduate holding her navy gown draped over one arm in front of a colorful painting.' },
  { img: g7, alt: 'Still life of a graduation cap and tassel resting on a stack of upholstery fabric binders.' },
  { img: g8, alt: 'Graduate working on a laptop from a showroom sofa, photographed in soft window light.' },
  { img: g9, alt: 'Graduate seated in an upholstered chair, holding her tassel out toward the camera.' },
];

const tiers = [
  {
    name: 'The Moment',
    kicker: 'Entry level support',
    body: 'For the business that needs current, on brand images and does not need a full production. One focused session, delivered ready to publish.',
  },
  {
    name: 'The Momentum',
    kicker: 'Ongoing content',
    body: 'Regular sessions across the year so your brand imagery keeps pace with what you are actually launching, hiring for and selling.',
  },
  {
    name: 'The Archive',
    kicker: 'Comprehensive documentation',
    body: 'The full visual record of a company. Team, space, product, process and leadership, documented and organized so anyone on your team can pull the right frame.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The McKinnis Edit | Brand, Portrait and Event Photography in San Antonio</title>
    <meta
      name="description"
      content="The McKinnis Edit is a San Antonio photography studio led by Michael McKinnis, offering brand, portrait, headshot and event photography for clients across Texas."
    />
    <link rel="canonical" href="https://on-par.github.io/mckinnis-edit-site/" />
    <meta name="theme-color" content="#243b6c" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="The McKinnis Edit" />
    <meta
      property="og:description"
      content="Brand, portrait, headshot and event photography in San Antonio, Texas."
    />
    <meta property="og:url" content="https://on-par.github.io/mckinnis-edit-site/" />
    <link rel="icon" href={`${base}/favicon-32.png`} sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
    <meta property="og:image" content="https://on-par.github.io/mckinnis-edit-site/logo-512.png" />
  </head>
  <body>
    <a class="skip" href="#top">Skip to content</a>

    <header class="site-head" id="site-head">
      <div class="wrap head-inner">
        <a class="mark" href="#top" aria-label="The McKinnis Edit, home">
          <Image
            src={logoLight}
            alt="The McKinnis Edit"
            widths={[180, 360]}
            sizes="180px"
            loading="eager"
            format="png"
          />
          <span class="mark-text">
            <span class="mark-1">The McKinnis</span> <span class="mark-2">Edit</span>
          </span>
        </a>
        <nav class="nav" aria-label="Primary">
          {nav.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
        <a class="head-cta" href={`mailto:${email}`}>Book</a>
      </div>
    </header>

    <main id="top">
      <!-- HERO -->
      <section class="hero dark" aria-labelledby="hero-title">
        <div class="wrap hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">San Antonio, Texas</p>
            <h1 id="hero-title">
              The McKinnis <em>Edit</em>
            </h1>
            <hr class="rule" />
            <p class="lede">
              Brand, portrait, headshot and event photography for people who are building
              something. Nearly thirty years behind the camera, applied to one story at a time.
            </p>
            <div class="hero-actions">
              <a class="btn btn-solid" href={`mailto:${email}`}>Book a session</a>
              <a class="btn" href="#work">View the work</a>
            </div>
          </div>
          <figure class="hero-figure">
            <Image
              src={hero}
              alt="Graduate in a navy gown and orange dress reaching toward a wall of design samples, photographed by The McKinnis Edit."
              widths={[420, 720, 1080]}
              sizes="(max-width: 900px) 88vw, 42vw"
              loading="eager"
              fetchpriority="high"
              format="webp"
              quality={72}
            />
            <figcaption>Graduate session, San Antonio</figcaption>
          </figure>
        </div>
      </section>

      <!-- BRAND STATEMENT -->
      <section class="statement" aria-labelledby="statement-title">
        <div class="wrap">
          <p class="eyebrow">The edit</p>
          <h2 id="statement-title" class="reveal">
            Every image is a choice. A point of view. An edit.
          </h2>
          <div class="statement-body reveal">
            <p>
              The McKinnis Edit sits between fine art photography and commercial brand work. Not a
              budget studio, not an agency queue. A working partnership with one photographer who
              learns your business before he picks up a camera.
            </p>
            <p>
              The result is a set of images that hold together. They look like you on your clearest
              day, and they keep working long after the session ends.
            </p>
          </div>
        </div>
      </section>

      <!-- SERVICES -->
      <section id="services" class="services" aria-labelledby="services-title">
        <div class="wrap">
          <p class="eyebrow">Services</p>
          <h2 id="services-title">Four ways to work together</h2>
          <div class="svc-grid">
            {
              services.map((s) => (
                <article class="svc reveal">
                  <div class="svc-img">
                    <Image
                      src={s.img}
                      alt={s.alt}
                      widths={[320, 520, 760]}
                      sizes="(max-width: 700px) 88vw, (max-width: 1100px) 44vw, 22vw"
                      loading="lazy"
                      format="webp"
                      quality={70}
                    />
                  </div>
                  <p class="svc-n">{s.n}</p>
                  <h3>{s.title}</h3>
                  <p class="svc-body">{s.body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <!-- FEATURED WORK -->
      <section id="work" class="work dark" aria-labelledby="work-title">
        <div class="wrap">
          <p class="eyebrow">Featured work</p>
          <h2 id="work-title">Selected frames</h2>
          <p class="work-note">
            A graduate session photographed in a San Antonio design showroom. One afternoon, one
            person, one story told all the way through.
          </p>
          <div class="gallery">
            {
              gallery.map((item) => (
                <figure class="shot reveal">
                  <Image
                    src={item.img}
                    alt={item.alt}
                    widths={[320, 520, 760]}
                    sizes="(max-width: 700px) 88vw, (max-width: 1100px) 44vw, 30vw"
                    loading="lazy"
                    format="webp"
                    quality={70}
                  />
                </figure>
              ))
            }
          </div>
        </div>
      </section>

      <!-- MEMBERSHIPS -->
      <section id="memberships" class="memberships" aria-labelledby="memberships-title">
        <div class="wrap">
          <p class="eyebrow">Brand retainer memberships</p>
          <h2 id="memberships-title">Photography that keeps up with the business</h2>
          <p class="section-lede">
            Most brands do not need one shoot. They need images arriving all year, in the same
            voice. Three tiers, one standard.
          </p>
          <div class="tiers">
            {
              tiers.map((t) => (
                <article class="tier reveal">
                  <p class="tier-kicker">{t.kicker}</p>
                  <h3>{t.name}</h3>
                  <p>{t.body}</p>
                </article>
              ))
            }
          </div>
          <div class="steps reveal">
            <div class="step">
              <h3>The Foundation</h3>
              <p>
                Every membership opens here. A working session on your brand, your audience and the
                shot list that follows from both, so the first frame is already on strategy.
              </p>
            </div>
            <div class="step">
              <h3>The Launch</h3>
              <p>
                A starting package for new clients with something to announce. Built for the moment
                a business, a role or a book goes public.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- WORKSHOPS -->
      <section id="workshops" class="workshops dark" aria-labelledby="workshops-title">
        <div class="wrap ws-grid">
          <figure class="ws-figure reveal">
            <Image
              src={workshopImg}
              alt="Close portrait of a graduate making a university hand sign, lit with soft directional light."
              widths={[380, 620, 900]}
              sizes="(max-width: 900px) 88vw, 38vw"
              loading="lazy"
              format="webp"
              quality={70}
            />
          </figure>
          <div class="ws-copy">
            <p class="eyebrow">Workshops</p>
            <h2 id="workshops-title">Learn the craft in the room</h2>
            <p>
              Live sessions for aspiring photographers and creatives. Recent workshops have covered
              lighting, posing and framing, taught the way they are actually used on a paid job
              rather than in theory.
            </p>
            <p>
              Every workshop runs a standard tier, with a VIP Business Strategy upgrade for
              photographers who want to talk pricing, packaging and how the work becomes a
              business.
            </p>
            <a class="btn" href={`mailto:${email}?subject=Workshop%20interest`}
              >Ask about the next date</a
            >
          </div>
        </div>
      </section>

      <!-- ABOUT -->
      <section id="about" class="about" aria-labelledby="about-title">
        <div class="wrap about-grid">
          <div class="about-copy">
            <p class="eyebrow">About</p>
            <h2 id="about-title">Michael McKinnis</h2>
            <p>
              Michael has spent nearly thirty years making photographs. The studio was formerly
              known as Eye Soul Photography and was reestablished as The McKinnis Edit to reflect a
              more intentional, editorial approach to visual storytelling. The name is the promise:
              refinement, curation, a point of view.
            </p>
            <p>
              He works with entrepreneurs, business owners and professionals across Texas, including
              San Antonio, Austin, Houston and Dallas. Clients tend to arrive at a threshold. A
              launch, a new role, a milestone. That is the work he likes best.
            </p>
            <h3>Cerissa McKinnis</h3>
            <p>
              Michael's wife, Cerissa, is a key creative and brand advisor to the studio. She is the
              author of <em>Navigating the Liminal Places</em>, a book about life's transitional
              moments seen through the lens of interior design. That sensibility, the belief that a
              space and a season shape how a person shows up, runs straight through the way this
              studio sees a room and the person standing in it.
            </p>
          </div>
          <div class="about-figures">
            <figure class="reveal">
              <Image
                src={aboutBook}
                alt="Graduate seated on a sofa holding open a copy of Navigating the Liminal Places by Cerissa LaToi McKinnis."
                widths={[360, 560, 820]}
                sizes="(max-width: 900px) 88vw, 30vw"
                loading="lazy"
                format="webp"
                quality={70}
              />
              <figcaption>Navigating the Liminal Places by Cerissa McKinnis</figcaption>
            </figure>
            <figure class="reveal offset">
              <Image
                src={aboutSecond}
                alt="Still life of a graduation cap and tassel resting on a stack of striped upholstered boxes."
                widths={[300, 480, 720]}
                sizes="(max-width: 900px) 88vw, 24vw"
                loading="lazy"
                format="webp"
                quality={70}
              />
            </figure>
          </div>
        </div>
      </section>

      <!-- CONTACT -->
      <section id="contact" class="contact dark" aria-labelledby="contact-title">
        <div class="wrap contact-inner">
          <p class="eyebrow">Contact</p>
          <h2 id="contact-title">LET'S CREATE TOGETHER</h2>
          <p class="contact-lede">
            Tell me what you are building and when you need the images. I will come back with a
            plan, a date and a clear price.
          </p>
          <a class="btn btn-solid contact-btn" href={`mailto:${email}`}>{email}</a>
          <p class="contact-meta">
            San Antonio, Texas<br />
            Serving San Antonio, Austin, Houston and Dallas
          </p>
        </div>
      </section>
    </main>

    <footer class="foot">
      <div class="wrap foot-inner">
        <div class="foot-logo">
          <Image
            src={logoLight}
            alt="The McKinnis Edit"
            widths={[260, 520]}
            sizes="260px"
            loading="lazy"
            format="png"
          />
        </div>
        <p class="foot-meta">
          San Antonio, Texas &middot; <a href={`mailto:${email}`}>{email}</a>
        </p>
        <p class="foot-fine">
          All photography is original work by Michael McKinnis / The McKinnis Edit.
        </p>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var head = document.getElementById('site-head');
        var onScroll = function () {
          if (window.scrollY > 40) head.classList.add('is-stuck');
          else head.classList.remove('is-stuck');
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });

        var els = document.querySelectorAll('.reveal');
        if (!('IntersectionObserver' in window)) {
          els.forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
        );
        els.forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>

    <style>
      /* ---------- Header ---------- */
      .site-head {
        position: sticky;
        top: 0;
        /* Sits above every section, and isolates so no image can paint into it. */
        z-index: 1000;
        isolation: isolate;
        background: var(--navy);
        border-bottom: 1px solid rgba(209, 165, 74, 0.28);
        transition: box-shadow 0.3s ease;
      }
      .site-head.is-stuck {
        box-shadow: 0 8px 30px rgba(27, 44, 81, 0.35);
      }
      .head-inner {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        min-height: 4.25rem;
        justify-content: space-between;
      }
      .mark {
        display: flex;
        align-items: center;
        text-decoration: none;
        flex: 0 0 auto;
      }
      .mark :global(img) {
        height: clamp(2rem, 1.6rem + 1.3vw, 2.6rem);
        width: auto;
      }
      .mark-text {
        font-family: var(--serif);
        font-size: clamp(1rem, 0.9rem + 0.5vw, 1.2rem);
        color: var(--cream);
        letter-spacing: 0.02em;
        white-space: nowrap;
        padding-left: 0.85rem;
        margin-left: 0.85rem;
        border-left: 1px solid rgba(209, 165, 74, 0.35);
      }
      .mark-2 {
        font-style: italic;
        color: var(--gold);
      }
      @media (max-width: 420px) {
        .mark-text {
          display: none;
        }
      }
      .nav {
        display: flex;
        flex-wrap: wrap;
        gap: clamp(0.85rem, 1.6vw, 1.9rem);
      }
      .nav a {
        font-size: 0.7rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--tan);
        text-decoration: none;
        padding-block: 0.35rem;
        border-bottom: 1px solid transparent;
        transition: color 0.25s ease, border-color 0.25s ease;
      }
      .nav a:hover,
      .nav a:focus-visible {
        color: var(--gold);
        border-color: var(--gold);
      }
      .head-cta {
        font-size: 0.68rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        text-decoration: none;
        color: var(--navy);
        background: var(--gold);
        padding: 0.6rem 1.15rem;
        transition: opacity 0.25s ease;
      }
      .head-cta:hover {
        opacity: 0.85;
      }
      @media (max-width: 860px) {
        .head-inner {
          flex-wrap: wrap;
          padding-block: 0.85rem;
          gap: 0.6rem 1rem;
        }
        /* Keep the nav to a single row so the sticky header stays shallow. */
        .nav {
          order: 3;
          width: 100%;
          flex-wrap: nowrap;
          justify-content: space-between;
          gap: 0.4rem;
          overflow-x: auto;
          scrollbar-width: none;
        }
        .nav::-webkit-scrollbar {
          display: none;
        }
        .nav a {
          font-size: 0.58rem;
          letter-spacing: 0.06em;
          white-space: nowrap;
        }
      }

      /* ---------- Hero ---------- */
      .hero {
        padding-block: clamp(3.5rem, 8vw, 7.5rem);
        background:
          radial-gradient(120% 80% at 85% 10%, rgba(174, 191, 175, 0.14), transparent 60%),
          var(--navy);
      }
      .hero-grid {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: clamp(2rem, 5vw, 4.5rem);
        align-items: center;
      }
      .hero h1 {
        font-size: clamp(2.9rem, 1.6rem + 6vw, 6.2rem);
        line-height: 0.98;
        color: var(--cream);
        margin: 0 0 1.75rem;
      }
      .hero h1 em {
        display: block;
        font-style: italic;
        color: var(--gold);
      }
      .lede {
        font-size: clamp(1.02rem, 0.98rem + 0.3vw, 1.18rem);
        color: var(--tan);
        max-width: 40ch;
      }
      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem;
        margin-top: 2.25rem;
      }
      .hero-figure {
        margin: 0;
        position: relative;
      }
      .hero-figure img {
        width: 100%;
        aspect-ratio: 4 / 5;
        object-fit: cover;
        border: 1px solid rgba(209, 165, 74, 0.35);
      }
      .hero-figure figcaption {
        font-size: 0.68rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--sage);
        margin-top: 0.9rem;
      }
      @media (max-width: 900px) {
        .hero-grid {
          grid-template-columns: 1fr;
        }
        .hero-figure {
          order: -1;
        }
        .hero-figure img {
          aspect-ratio: 3 / 4;
        }
      }

      /* ---------- Brand statement ---------- */
      .statement {
        background: var(--cream);
      }
      .statement h2 {
        font-size: clamp(1.9rem, 1.2rem + 3.2vw, 3.5rem);
        max-width: 20ch;
        margin-bottom: 2.5rem;
        color: var(--navy);
      }
      .statement-body {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 0 clamp(2rem, 5vw, 4rem);
        max-width: 62rem;
      }
      .statement-body p {
        max-width: 46ch;
      }

      /* ---------- Services ---------- */
      .services {
        background: #f3ece5;
      }
      .services h2 {
        font-size: clamp(1.7rem, 1.2rem + 2.4vw, 2.8rem);
        color: var(--navy);
        margin-bottom: clamp(2.5rem, 5vw, 4rem);
      }
      .svc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: clamp(1.75rem, 3vw, 2.75rem);
      }
      .svc-img img {
        width: 100%;
        aspect-ratio: 3 / 4;
        object-fit: cover;
        filter: saturate(0.96);
        transition: transform 0.7s ease;
      }
      .svc-img {
        overflow: hidden;
        margin-bottom: 1.4rem;
      }
      .svc:hover .svc-img img {
        transform: scale(1.03);
      }
      .svc-n {
        font-size: 0.68rem;
        letter-spacing: 0.24em;
        color: var(--gold);
        margin: 0 0 0.5rem;
      }
      .svc h3 {
        font-size: 1.35rem;
        color: var(--navy);
        margin-bottom: 0.7rem;
      }
      .svc-body {
        font-size: 0.94rem;
        color: var(--ink-soft);
        line-height: 1.7;
      }

      /* ---------- Featured work ---------- */
      .work h2 {
        font-size: clamp(1.7rem, 1.2rem + 2.4vw, 2.8rem);
      }
      .work-note {
        color: var(--tan);
        max-width: 48ch;
        margin-top: 1.1rem;
        margin-bottom: clamp(2.5rem, 5vw, 3.75rem);
      }
      /* Nine frames, held in a deliberate 3 by 3 block. */
      .gallery {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(0.75rem, 1.6vw, 1.35rem);
      }
      @media (max-width: 860px) {
        .gallery {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 520px) {
        .gallery {
          grid-template-columns: 1fr;
          gap: 1rem;
        }
      }
      .shot {
        margin: 0;
        overflow: hidden;
      }
      .shot img {
        width: 100%;
        aspect-ratio: 3 / 4;
        object-fit: cover;
        transition: transform 0.8s ease, opacity 0.5s ease;
      }
      .shot:hover img {
        transform: scale(1.04);
      }

      /* ---------- Memberships ---------- */
      .memberships {
        background: var(--cream);
      }
      .memberships h2 {
        font-size: clamp(1.7rem, 1.2rem + 2.4vw, 2.8rem);
        color: var(--navy);
        max-width: 18ch;
      }
      .section-lede {
        margin-top: 1.15rem;
        margin-bottom: clamp(2.5rem, 5vw, 3.75rem);
        max-width: 46ch;
        color: var(--ink-soft);
      }
      .tiers {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: clamp(1.25rem, 2.5vw, 2rem);
      }
      .tier {
        background: #fff;
        border: 1px solid rgba(36, 59, 108, 0.12);
        border-top: 3px solid var(--gold);
        padding: clamp(1.5rem, 3vw, 2.25rem);
        transition: transform 0.4s ease, box-shadow 0.4s ease;
      }
      .tier:hover {
        transform: translateY(-4px);
        box-shadow: 0 18px 40px rgba(36, 59, 108, 0.1);
      }
      .tier-kicker {
        font-size: 0.66rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 0.6rem;
      }
      .tier h3 {
        font-size: 1.55rem;
        color: var(--navy);
        margin-bottom: 0.85rem;
      }
      .tier p {
        font-size: 0.94rem;
        color: var(--ink-soft);
        margin: 0;
      }
      .steps {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: clamp(1.5rem, 4vw, 3.5rem);
        margin-top: clamp(2.5rem, 5vw, 4rem);
        padding-top: clamp(2rem, 4vw, 3rem);
        border-top: 1px solid rgba(36, 59, 108, 0.15);
      }
      .step h3 {
        font-size: 1.25rem;
        color: var(--navy);
        margin-bottom: 0.6rem;
      }
      .step p {
        font-size: 0.94rem;
        color: var(--ink-soft);
        margin: 0;
      }

      /* ---------- Workshops ---------- */
      .ws-grid {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: clamp(2rem, 5vw, 4.5rem);
        align-items: center;
      }
      .ws-figure {
        margin: 0;
      }
      .ws-figure img {
        width: 100%;
        aspect-ratio: 4 / 5;
        object-fit: cover;
        border: 1px solid rgba(209, 165, 74, 0.3);
      }
      .workshops h2 {
        font-size: clamp(1.7rem, 1.2rem + 2.4vw, 2.8rem);
        margin-bottom: 1.4rem;
      }
      .workshops p {
        color: var(--tan);
        max-width: 48ch;
      }
      .workshops .btn {
        margin-top: 1rem;
      }
      @media (max-width: 900px) {
        .ws-grid {
          grid-template-columns: 1fr;
        }
      }

      /* ---------- About ---------- */
      .about {
        background: #f3ece5;
      }
      .about-grid {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: clamp(2rem, 5vw, 4.5rem);
        align-items: start;
      }
      .about h2 {
        font-size: clamp(1.8rem, 1.2rem + 2.6vw, 3rem);
        color: var(--navy);
        margin-bottom: 1.5rem;
      }
      .about h3 {
        font-size: 1.35rem;
        color: var(--navy);
        margin: 2.25rem 0 0.8rem;
      }
      .about p {
        color: var(--ink-soft);
      }
      .about-figures {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: clamp(0.75rem, 2vw, 1.25rem);
        align-items: start;
      }
      .about-figures figure {
        margin: 0;
      }
      .about-figures img {
        width: 100%;
        aspect-ratio: 3 / 4;
        object-fit: cover;
      }
      /* The book frame is a tall crop; hold the top so the cover stays in view. */
      .about-figures figure:first-child img {
        aspect-ratio: 3 / 4.6;
        object-position: 50% 12%;
      }
      .about-figures .offset {
        margin-top: clamp(1.5rem, 4vw, 3.5rem);
      }
      .about-figures figcaption {
        font-size: 0.68rem;
        letter-spacing: 0.1em;
        color: var(--ink-soft);
        margin-top: 0.7rem;
        line-height: 1.5;
      }
      @media (max-width: 900px) {
        .about-grid {
          grid-template-columns: 1fr;
        }
      }

      /* ---------- Contact ---------- */
      .contact {
        background:
          radial-gradient(90% 120% at 50% 0%, rgba(209, 165, 74, 0.16), transparent 65%),
          var(--navy-deep);
        text-align: center;
      }
      .contact-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .contact h2 {
        font-size: clamp(1.9rem, 1.1rem + 4vw, 4.25rem);
        letter-spacing: 0.02em;
        margin-bottom: 1.5rem;
      }
      .contact-lede {
        color: var(--tan);
        max-width: 44ch;
        margin-bottom: 2.25rem;
      }
      .contact-btn {
        font-size: 0.8rem;
        letter-spacing: 0.12em;
        text-transform: none;
        word-break: break-word;
      }
      .contact-meta {
        margin-top: 2.5rem;
        font-size: 0.78rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--sage);
        line-height: 2;
      }

      /* ---------- Footer ---------- */
      .foot {
        background: var(--navy);
        border-top: 1px solid rgba(209, 165, 74, 0.25);
        padding-block: 3rem;
        color: var(--tan);
      }
      .foot-inner {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }
      .foot-logo {
        margin-bottom: 0.75rem;
      }
      .foot-logo :global(img) {
        height: 3rem;
        width: auto;
      }
      .foot-meta {
        margin: 0;
        font-size: 0.85rem;
      }
      .foot-meta a {
        color: var(--gold);
        text-decoration: none;
      }
      .foot-meta a:hover {
        text-decoration: underline;
      }
      .foot-fine {
        margin: 0;
        font-size: 0.75rem;
        color: var(--sage);
      }
    </style>
  </body>
</html>
